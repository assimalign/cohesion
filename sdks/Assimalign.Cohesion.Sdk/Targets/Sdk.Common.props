<Project>
	<PropertyGroup>
		<CohesionSdkType Condition="'$(CohesionSdkType)' == ''">Common</CohesionSdkType>
		<TargetFramework Condition="'$(TargetFramework)' == '' and '$(TargetFrameworks)' == ''">net10.0</TargetFramework>
		<LangVersion Condition="'$(LangVersion)' == ''">Preview</LangVersion>
		<EnablePreviewFeatures Condition="'$(EnablePreviewFeatures)' == ''">true</EnablePreviewFeatures>
		<Nullable Condition="'$(Nullable)' == ''">enable</Nullable>
	</PropertyGroup>
	
	<UsingTask
		TaskName="Assimalign.Cohesion.Sdk.Tasks.CreateValueTypeTask"
		AssemblyFile="$(MSBuildThisFileDirectory)..\Tasks\Assimalign.Cohesion.Sdk.Tasks.dll"
		Runtime="NET" />
    
    <!--<ItemGroup Condition="'$(CohesionResourceType)' == 'ConfigurationStore'">
        <PackageReference Include="Assimalign.Cohesion.App" Version="$(CohesionVersion)" />
    </ItemGroup>-->
</Project>
