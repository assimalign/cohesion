<Project>
    <UsingTask
		TaskName="Assimalign.Cohesion.Sdk.Tasks.CreateStronglyTypedSettingsTask"
		AssemblyFile="..\Tasks\Assimalign.Cohesion.Sdk.Tasks.dll"
		Runtime="NET" />

	<PropertyGroup>
        <AppSettingsClass Condition="'$(AppSettingsClass)' == ''">AppSettings</AppSettingsClass>
        <AppSettingsNamespace Condition="'$(AppSettingsNamespace)' == ''">$(RootNamespace)</AppSettingsNamespace>
    </PropertyGroup>
</Project>