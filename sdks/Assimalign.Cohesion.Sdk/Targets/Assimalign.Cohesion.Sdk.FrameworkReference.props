<Project>
    <!--
        Registers the Cohesion shared framework family with the .NET SDK.

        Three frameworks are registered here, all on the base SDK so the
        registrations are available to consumers using any chained SDK:

            Assimalign.Cohesion.App           (base)
            Assimalign.Cohesion.App.Web       (web extension)
            Assimalign.Cohesion.App.Database  (database extension)

        Each SDK auto-includes the right set of <FrameworkReference>s:
            Sdk          -> App                (this file)
            Sdk.Web      -> App + App.Web      (Sdk.Web's Sdk.props adds App.Web)
            Sdk.Database -> App + App.Database (Sdk.Database's Sdk.props adds App.Database)

        Pack resolution: the SDK looks for these packs locally under
        $(NetCoreTargetingPackRoot) / $(NetCoreRuntimePackRoot). When not
        found there (the normal case for third-party frameworks), the SDK
        auto-restores them from the configured NuGet feeds.

        CohesionAutoIncludeAppFramework=false disables the implicit
        <FrameworkReference> on App (and any chained SDK's auto-include).
        The KnownFrameworkReference registrations stay so explicit
        <FrameworkReference> entries keep working.

        CohesionAppFrameworkVersion lets consumers pin or roll forward
        independently of the SDK version. All three frameworks share it.
    -->

    <PropertyGroup>
        <CohesionAppFrameworkVersion Condition="'$(CohesionAppFrameworkVersion)' == ''">$(CohesionVersion)</CohesionAppFrameworkVersion>
    </PropertyGroup>

    <ItemGroup>
        <KnownFrameworkReference Include="Assimalign.Cohesion.App"
            TargetFramework="net10.0"
            RuntimeFrameworkName="Assimalign.Cohesion.App"
            DefaultRuntimeFrameworkVersion="$(CohesionAppFrameworkVersion)"
            LatestRuntimeFrameworkVersion="$(CohesionAppFrameworkVersion)"
            TargetingPackName="Assimalign.Cohesion.App.Ref"
            TargetingPackVersion="$(CohesionAppFrameworkVersion)"
            RuntimePackNamePatterns="Assimalign.Cohesion.App.Runtime.**RID**"
            RuntimePackRuntimeIdentifiers="win-x64;win-arm64;linux-x64;linux-arm64;linux-musl-x64;osx-x64;osx-arm64"
            IsTrimmable="true" />

        <KnownFrameworkReference Include="Assimalign.Cohesion.App.Web"
            TargetFramework="net10.0"
            RuntimeFrameworkName="Assimalign.Cohesion.App.Web"
            DefaultRuntimeFrameworkVersion="$(CohesionAppFrameworkVersion)"
            LatestRuntimeFrameworkVersion="$(CohesionAppFrameworkVersion)"
            TargetingPackName="Assimalign.Cohesion.App.Web.Ref"
            TargetingPackVersion="$(CohesionAppFrameworkVersion)"
            RuntimePackNamePatterns="Assimalign.Cohesion.App.Web.Runtime.**RID**"
            RuntimePackRuntimeIdentifiers="win-x64;win-arm64;linux-x64;linux-arm64;linux-musl-x64;osx-x64;osx-arm64"
            IsTrimmable="true" />

        <KnownFrameworkReference Include="Assimalign.Cohesion.App.Database"
            TargetFramework="net10.0"
            RuntimeFrameworkName="Assimalign.Cohesion.App.Database"
            DefaultRuntimeFrameworkVersion="$(CohesionAppFrameworkVersion)"
            LatestRuntimeFrameworkVersion="$(CohesionAppFrameworkVersion)"
            TargetingPackName="Assimalign.Cohesion.App.Database.Ref"
            TargetingPackVersion="$(CohesionAppFrameworkVersion)"
            RuntimePackNamePatterns="Assimalign.Cohesion.App.Database.Runtime.**RID**"
            RuntimePackRuntimeIdentifiers="win-x64;win-arm64;linux-x64;linux-arm64;linux-musl-x64;osx-x64;osx-arm64"
            IsTrimmable="true" />
    </ItemGroup>

    <!-- The base SDK auto-includes only the App framework. Sdk.Web and
         Sdk.Database layer their own framework references on top in their
         own Sdk.props files. -->
    <ItemGroup Condition="'$(CohesionAutoIncludeAppFramework)' != 'false'">
        <FrameworkReference Include="Assimalign.Cohesion.App" />
    </ItemGroup>
</Project>
