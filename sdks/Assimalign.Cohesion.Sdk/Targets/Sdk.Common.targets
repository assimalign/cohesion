<Project>
	<ItemGroup>
		<PackageReference Include="Assimalign.Cohesion.Core" Version="$(CohesionVersion)" />
	</ItemGroup>


	<!-- #region: Code Generation: Create Value Types Targets -->
	<ItemGroup>
		<CreateValueType
			Update="@(CreateValueType)"
			ObjectFilePath="$(MSBuildProjectDirectory)\create-value-types\%(Identity)"
			ObjectRelativePath="%(Identity)" />
	</ItemGroup>
	<Target Name="CohesionCreateValueType" BeforeTargets="CoreCompile" Inputs="@(CreateValueType->'%(ObjectFilePath)')" Outputs="@(CreateValueType->'%(ObjectFilePath)')">
		<CodeGenerationCreateValueTypeTask ValueTypes="@(CreateValueType)" CodeGenOutputPath="$(CohesionOutputPathForCodeGen)\create-value-types">
			<Output TaskParameter="ValueTypesCreated" ItemName="ValueTypesGenerated" />
		</CodeGenerationCreateValueTypeTask>
		<!-- DEBUG: <Message Text="My ValueTypes: @(CohesionCodeGenValueType)" Importance="high" /> -->
	</Target>
	<ItemGroup>
		<Compile Include="@(CreateValueType->'%(ObjectFilePath)')" Link="/%(ObjectRelativePath)" />
	</ItemGroup>
	<!-- #endregion -->
</Project>
