<Project>
    <!-- #region Packages & Dependencies -->
    <ItemGroup>
        <_CohesionPackage Include="Sharprompt" Version="3.0.0" />
        <_CohesionPackage Include="KubernetesClient" Version="17.0.4" />
        <_CohesionPackage Include="NUlid" Version="1.7.2" />
    </ItemGroup>

    <!-- Analyzer & Build Dependencies -->
    <ItemGroup>
        <_CohesionPackage Include="Microsoft.CodeAnalysis.Analyzers" Version="3.11.0" />
        <_CohesionPackage Include="Microsoft.CodeAnalysis.CSharp" Version="5.0.0" />
        <_CohesionPackage Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="5.0.0">
            <PrivateAssets>all</PrivateAssets>
        </_CohesionPackage>
        <_CohesionPackage Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="5.0.0">
            <PrivateAssets>all</PrivateAssets>
        </_CohesionPackage>
        <_CohesionPackage Include="Microsoft.Build" Version="18.0.2">
            <PrivateAssets>all</PrivateAssets>
            <ExcludeAssets>all</ExcludeAssets>
        </_CohesionPackage>
        <_CohesionPackage Include="Microsoft.Build.Framework" Version="18.0.2">
            <PrivateAssets>all</PrivateAssets>
            <ExcludeAssets>all</ExcludeAssets>
        </_CohesionPackage>
        <_CohesionPackage Include="Microsoft.Build.Utilities.Core" Version="18.0.2">
            <PrivateAssets>all</PrivateAssets>
            <ExcludeAssets>all</ExcludeAssets>
        </_CohesionPackage>
        <_CohesionPackage Include="Microsoft.Build.Locator" Version="1.11.2" />
    </ItemGroup>

    <!-- XUnit Test Dependencies-->
    <ItemGroup>
        <_CohesionPackage Include="FluentAssertions" Version="8.5.0" />
        <_CohesionPackage Include="xunit" Version="2.9.3" />
        <_CohesionPackage Include="Microsoft.NET.Test.Sdk" Version="18.0.1" />
        <_CohesionPackage Include="xunit.runner.visualstudio" Version="3.1.5"
            IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive"
            PrivateAssets="all" />
        <_CohesionPackage Include="coverlet.collector" Version="6.0.4">
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
            <PrivateAssets>all</PrivateAssets>
        </_CohesionPackage>
    </ItemGroup>

    <!-- PowerShell Binary Module Dependencies  -->
    <ItemGroup>
        <_CohesionPackage Include="System.Management.Automation" Version="7.6.0-preview.5" />
    </ItemGroup>

    <!-- #region: Package Reference Update -->
    <ItemGroup>
        <CohesionPackageReference Update="@(_CohesionPackage)" Version="%(_CohesionPackage.Version)" />
        <PackageReference Include="@(CohesionPackageReference)" />
        <CohesionPackageReference Remove="@(CohesionPackageReference)" />
    </ItemGroup>
    <!-- #endregion -->
</Project>