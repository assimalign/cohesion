<Project>
    <!-- #region Packages & Dependencies -->
    <ItemGroup>
        <PackageReferenceProvider Include="System.IO.Pipelines" Version="9.0.3" />
        <PackageReferenceProvider Include="Sharprompt" Version="3.0.0" />
    </ItemGroup>
    <ItemGroup>
        <PackageReferenceProvider Include="Microsoft.Build" Version="17.12.6" />
        <PackageReferenceProvider Include="Microsoft.Build.Framework" Version="17.12.6" />
        <PackageReferenceProvider Include="Microsoft.Build.Utilities.Core" Version="17.12.6" />
    </ItemGroup>
    <!-- XUnit Test Dependencies-->
    <ItemGroup>
        <PackageReferenceProvider Include="xunit" Version="2.9.3" />
        <PackageReferenceProvider Include="Microsoft.NET.Test.Sdk" Version="17.13.0" />
        <PackageReferenceProvider Include="xunit.runner.visualstudio" Version="3.0.2"
            IncludeAssets="runtime; build; native; contentfiles; analyzers; buildtransitive"
            PrivateAssets="all" />
        <PackageReferenceProvider Include="coverlet.collector" Version="6.0.4">
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
            <PrivateAssets>all</PrivateAssets>
        </PackageReferenceProvider>
    </ItemGroup>
    <ItemGroup>
        <Reference Update="@(PackageReferenceProvider)" Version="%(PackageReferenceProvider.Version)" />
        <PackageReference Include="@(Reference->HasMetadata('Version'))" />
        <PackageReference Update="@(PackageReferenceProvider)" Version="%(PackageReferenceProvider.Version)" />
        <Reference Remove="@(Reference->HasMetadata('Version'))" />
    </ItemGroup>
</Project>