<Project>
    <!--
        Project Reference By Name Only.

        Lets a library/resource csproj reference another by its assembly name
        instead of by relative csproj path. Resolution walks libraries/ and
        resources/ once, matches each <CohesionProjectReference Include="X" />
        to the csproj whose filename is "X.csproj", and emits a regular
        <ProjectReference Include="<resolved-path>" />.

        Two flavours:

          CohesionProjectReference        - PUBLIC. Resulting <ProjectReference>
                                            has default semantics: the target
                                            is compiled against, CopyLocal'd
                                            into bin/, AND appears as a
                                            <dependency> in this library's
                                            .nupkg .nuspec (flows to consumers).

          CohesionPrivateProjectReference - PRIVATE. Same compile + CopyLocal
                                            behaviour, but the resulting
                                            <ProjectReference> carries
                                            PrivateAssets="all", which
                                            suppresses the <dependency> entry
                                            in the .nuspec. Consumers of this
                                            library's .nupkg never learn about
                                            the target.

                                            Use for "this library needs X as
                                            an internal implementation detail
                                            but should not expose X to its
                                            consumers". Pair with a matching
                                            <CohesionFrameworkPrivateAssembly>
                                            entry in
                                            frameworks/Assimalign.Cohesion.App.props
                                            so the containing framework's
                                            Runtime pack still ships X.dll at
                                            run time.
    -->
    <ItemGroup>
        <!-- Index all candidate projects ONCE. -->
        <_CohesionProject Include="$(CohesionRepositoryDirectory)libraries\**\*.csproj;$(CohesionRepositoryDirectory)resources\**\*.csproj" />
        <_CohesionProject Update="@(_CohesionProject)" ProjectId="%(_CohesionProject.Filename)" ProjectPath="%(_CohesionProject.Identity)" />

        <!-- Public refs -->
        <CohesionProjectReference Update="@(_CohesionProject->'%(ProjectId)')" ProjectPath="%(_CohesionProject.ProjectPath)" />
        <ProjectReference Include="@(CohesionProjectReference->'%(ProjectPath)')" />
        <CohesionProjectReference Remove="@(CohesionProjectReference->HasMetadata('ProjectPath'))" />

        <!-- Private refs: PrivateAssets='all' suppresses .nuspec <dependency> flow. -->
        <CohesionPrivateProjectReference Update="@(_CohesionProject->'%(ProjectId)')" ProjectPath="%(_CohesionProject.ProjectPath)" />
        <ProjectReference Include="@(CohesionPrivateProjectReference->'%(ProjectPath)')" PrivateAssets="all" />
        <CohesionPrivateProjectReference Remove="@(CohesionPrivateProjectReference->HasMetadata('ProjectPath'))" />

        <_CohesionProject Remove="@(_CohesionProject)" />
    </ItemGroup>
</Project>
