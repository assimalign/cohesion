<Project>
    <!-- DON'T USE. THIS IS NOT READY -->
    <!-- 
        <CohesionSharedFile 
            Include="{ The Project name. Exclude '.csproj' }"
			File="{ The relative path of the file within the project you want to use }"
			FileDirectory="{ The relative path to link the file in the current project }" />

        Example: 
        <CohesionSharedFile 
                    Include="Assimalign.Cohesion.ObjectPool"
					File="DefaultObjectPool.T.TArgs.cs"
					FileDirectory="Shared" />
    -->
    <ItemGroup>
		<_CohesionSharedFiles Include="$(CohesionRepositoryDirectory)libraries\**\*.csproj" />
		<_CohesionSharedFiles Update="@(_CohesionSharedFiles)" ProjectId="%(_CohesionSharedFiles.Filename)" ProjectDirectory="%(_CohesionSharedFiles.RelativeDir)" />
		<CohesionSharedFile Update="@(_CohesionSharedFiles->'%(ProjectId)')" ProjectDirectory="%(_CohesionSharedFiles.ProjectDirectory)" />
		<CohesionSharedFile Update="@(CohesionSharedFile)" FilePath="%(ProjectDirectory)%(File)" />
		<Compile Include="@(CohesionSharedFile->'%(FilePath)')" />
        <Compile Update="@(CohesionSharedFile->'%(FilePath)')" Link="%(File)" />
        <CohesionSharedFile Remove="@(CohesionSharedFile)" />
	</ItemGroup>

    <Target Name="Build">
        <Message Text="Files @(CohesionSharedFile->'%(FileDirectory)')" Importance="high" />
    </Target>
</Project>