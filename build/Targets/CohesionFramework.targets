<Project>
    <!--
        Cohesion shared-framework collection.

        Imported by both Assimalign.Cohesion.App.Runtime (per-RID runtime pack)
        and Assimalign.Cohesion.App.Refs (targeting pack). Branches on the
        $(CohesionFrameworkKind) property the consumer csproj sets:

            Ref     -> produce ref/<tfm>/<dll> + data/FrameworkList.xml
            Runtime -> produce runtimes/<rid>/lib/<tfm>/<dll> + data/RuntimeList.xml

        Distribution is via NuGet - these targets just produce the .nupkg
        layouts the SDK's KnownFrameworkReference machinery expects to find
        when resolving <FrameworkReference Include="Assimalign.Cohesion.App" />.
        Consumers `dotnet restore` pulls the packs from whatever NuGet feed
        is configured (the in-tree _out/packages/ feed for local dev, or a
        real feed for shipped builds).
    -->

    <PropertyGroup>
        <_CohesionRuntimeProjectDir>$(CohesionRepositoryDirectory)frameworks\Assimalign.Cohesion.App.Runtime\src\</_CohesionRuntimeProjectDir>

        <!--
            Both packs read from the Runtime project's RID-less bin/ folder.
            That folder contains App.dll plus every transitively-referenced
            Cohesion.* DLL via CopyLocal, which is the full framework surface.

            obj/.../ref/ only contains the current project's own ref assembly,
            so reading from there would have made the targeting pack expose
            App.dll but not Core.dll or any other transitive Cohesion library.

            For the Runtime pack we further override below with $(OutputPath)
            so per-RID builds pick up their own bin/.../<tfm>/<rid>/ folder.
        -->
        <_CohesionFrameworkAssemblyDir>$(_CohesionRuntimeProjectDir)bin\$(Configuration)\$(TargetFrameworkLatest)\</_CohesionFrameworkAssemblyDir>

        <!--
            Filter pattern. We only ship Cohesion.* assemblies in the framework;
            third-party transitive DLLs that happen to be CopyLocal'd into bin
            (xunit, Newtonsoft.Json, etc.) stay out. Override on a Cohesion
            library that needs to ship a non-Cohesion DLL as part of the
            framework surface.
        -->
        <CohesionFrameworkAssemblyPattern Condition="'$(CohesionFrameworkAssemblyPattern)' == ''">Assimalign.Cohesion.*.dll</CohesionFrameworkAssemblyPattern>

        <_CohesionFrameworkListPath>$(IntermediateOutputPath)data\FrameworkList.xml</_CohesionFrameworkListPath>
        <_CohesionRuntimeListPath>$(IntermediateOutputPath)data\RuntimeList.xml</_CohesionRuntimeListPath>
    </PropertyGroup>

    <!-- Hook our collection target into NuGet's standard extension point for
         dynamically-added pack content. This is the documented pattern and
         is more reliable than slapping Pack="true" on items inside a target. -->
    <PropertyGroup>
        <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);CohesionCollectFrameworkPack</TargetsForTfmSpecificContentInPackage>
    </PropertyGroup>

    <!--
        Inline manifest writer. Emits FrameworkList.xml (for ref packs) or
        RuntimeList.xml (for runtime packs), reading AssemblyName + Version
        + PublicKeyToken from each assembly via System.Reflection.AssemblyName
        (mscorlib, always available; reads only the manifest so it works
        cross-architecture).
    -->
    <UsingTask TaskName="CohesionWriteFrameworkList"
               TaskFactory="RoslynCodeTaskFactory"
               AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
        <ParameterGroup>
            <Assemblies ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
            <FrameworkName Required="true" />
            <FrameworkVersion Required="true" />
            <TargetFrameworkVersion Required="true" />
            <RootElementName Required="true" />
            <OutputPath Required="true" />
        </ParameterGroup>
        <Task>
            <Using Namespace="System" />
            <Using Namespace="System.IO" />
            <Using Namespace="System.Linq" />
            <Using Namespace="System.Reflection" />
            <Using Namespace="System.Text" />
            <Code Type="Fragment" Language="cs"><![CDATA[
                Directory.CreateDirectory(Path.GetDirectoryName(OutputPath));
                var sb = new StringBuilder();
                sb.Append("<").Append(RootElementName)
                  .Append(" Name=\"").Append(FrameworkName).Append("\"")
                  .Append(" TargetFrameworkIdentifier=\".NETCoreApp\"")
                  .Append(" TargetFrameworkVersion=\"").Append(TargetFrameworkVersion).Append("\"")
                  .Append(" FrameworkName=\"").Append(FrameworkName).Append("\">\r\n");

                foreach (var item in Assemblies.OrderBy(i => Path.GetFileName(i.ItemSpec), StringComparer.OrdinalIgnoreCase))
                {
                    var path = item.ItemSpec;
                    var fileName = Path.GetFileName(path);
                    string asmName = Path.GetFileNameWithoutExtension(path);
                    string asmVersion = "0.0.0.0";
                    string publicKeyToken = "";
                    try
                    {
                        var name = AssemblyName.GetAssemblyName(path);
                        asmName = name.Name;
                        if (name.Version != null) { asmVersion = name.Version.ToString(); }
                        var pkt = name.GetPublicKeyToken();
                        if (pkt != null && pkt.Length > 0)
                        {
                            publicKeyToken = BitConverter.ToString(pkt).Replace("-", "").ToLowerInvariant();
                        }
                    }
                    catch (Exception ex)
                    {
                        Log.LogWarning("Could not read assembly metadata from " + path + ": " + ex.Message);
                    }

                    // PublicKeyToken is ALWAYS emitted (even empty for unsigned
                    // assemblies). The .NET SDK's ResolveTargetingPackAssets task
                    // dereferences .Attribute("PublicKeyToken").Value without a
                    // null-check; a missing attribute throws NullReferenceException
                    // during framework resolution in the consumer build.
                    sb.Append("  <File Type=\"Managed\"")
                      .Append(" Path=\"").Append(fileName).Append("\"")
                      .Append(" PublicKeyToken=\"").Append(publicKeyToken).Append("\"")
                      .Append(" AssemblyName=\"").Append(asmName).Append("\"")
                      .Append(" AssemblyVersion=\"").Append(asmVersion).Append("\"")
                      .Append(" FileVersion=\"").Append(FrameworkVersion).Append(".0\"")
                      .Append(" />\r\n");
                }

                sb.Append("</").Append(RootElementName).Append(">\r\n");
                File.WriteAllText(OutputPath, sb.ToString());
            ]]></Code>
        </Task>
    </UsingTask>

    <!--
        TfmSpecificPackageFile is NuGet's extension point for dynamically
        contributing package content. The target outputs items into that
        collection and NuGet picks them up during _GetPackageFiles.

        The branch by CohesionFrameworkKind keeps both packs (Ref and Runtime)
        on the same target import chain - they're truly mutually exclusive
        because each project sets one or the other.
    -->
    <Target Name="CohesionCollectFrameworkPack" DependsOnTargets="ResolveProjectReferences">

        <!-- ============ REF PACK ============ -->
        <ItemGroup Condition="'$(CohesionFrameworkKind)' == 'Ref'">
            <_CohesionRefAssembly Include="$(_CohesionFrameworkAssemblyDir)$(CohesionFrameworkAssemblyPattern)" />
        </ItemGroup>

        <Error Condition="'$(CohesionFrameworkKind)' == 'Ref' and '@(_CohesionRefAssembly)' == ''"
               Text="No framework assemblies found at '$(_CohesionFrameworkAssemblyDir)' matching '$(CohesionFrameworkAssemblyPattern)'. The App.Runtime project must build first." />

        <CohesionWriteFrameworkList Condition="'$(CohesionFrameworkKind)' == 'Ref'"
            Assemblies="@(_CohesionRefAssembly)"
            FrameworkName="$(CohesionFrameworkName)"
            FrameworkVersion="$(CohesionVersion)"
            TargetFrameworkVersion="10.0"
            RootElementName="FileList"
            OutputPath="$(_CohesionFrameworkListPath)" />

        <ItemGroup Condition="'$(CohesionFrameworkKind)' == 'Ref'">
            <TfmSpecificPackageFile Include="@(_CohesionRefAssembly)">
                <PackagePath>ref/$(TargetFrameworkLatest)/%(Filename)%(Extension)</PackagePath>
            </TfmSpecificPackageFile>
            <TfmSpecificPackageFile Include="$(_CohesionFrameworkListPath)">
                <PackagePath>data/FrameworkList.xml</PackagePath>
            </TfmSpecificPackageFile>
        </ItemGroup>

        <!-- ============ RUNTIME PACK ============ -->
        <!-- Only runs when an RID is explicitly set (dotnet pack -p:RuntimeIdentifier=win-x64).
             RID-less builds (the IDE design-time build) skip pack production. -->
        <ItemGroup Condition="'$(CohesionFrameworkKind)' == 'Runtime' and '$(RuntimeIdentifier)' != ''">
            <_CohesionImplAssembly Include="$(OutputPath)$(CohesionFrameworkAssemblyPattern)" />
        </ItemGroup>

        <Error Condition="'$(CohesionFrameworkKind)' == 'Runtime' and '$(RuntimeIdentifier)' != '' and '@(_CohesionImplAssembly)' == ''"
               Text="No implementation assemblies found at '$(OutputPath)' matching '$(CohesionFrameworkAssemblyPattern)'. Build must run before pack." />

        <CohesionWriteFrameworkList Condition="'$(CohesionFrameworkKind)' == 'Runtime' and '$(RuntimeIdentifier)' != ''"
            Assemblies="@(_CohesionImplAssembly)"
            FrameworkName="$(CohesionFrameworkName)"
            FrameworkVersion="$(CohesionVersion)"
            TargetFrameworkVersion="10.0"
            RootElementName="RuntimeList"
            OutputPath="$(_CohesionRuntimeListPath)" />

        <ItemGroup Condition="'$(CohesionFrameworkKind)' == 'Runtime' and '$(RuntimeIdentifier)' != ''">
            <TfmSpecificPackageFile Include="@(_CohesionImplAssembly)">
                <PackagePath>runtimes/$(RuntimeIdentifier)/lib/$(TargetFrameworkLatest)/%(Filename)%(Extension)</PackagePath>
            </TfmSpecificPackageFile>
            <TfmSpecificPackageFile Include="$(_CohesionRuntimeListPath)">
                <PackagePath>data/RuntimeList.xml</PackagePath>
            </TfmSpecificPackageFile>
        </ItemGroup>
    </Target>
</Project>
