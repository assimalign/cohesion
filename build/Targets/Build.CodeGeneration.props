<Project>
    <UsingTask
		TaskName="Assimalign.Cohesion.Build.Tasks.CodeGenerationCreateValueTypeTask"
		AssemblyFile="$(MSBuildThisFileDirectory)..\Tasks\bin\$(Configuration)\$(TargetFramework)\Assimalign.Cohesion.Build.Tasks.dll"
		Runtime="NET" />

	<PropertyGroup>
        <_CohesionCodeGenPath>$(_CohesionIntermediateOutputPath)CodeGeneration\</_CohesionCodeGenPath>
    </PropertyGroup>
</Project>