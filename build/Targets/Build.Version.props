<Project>
    <PropertyGroup>
        <!-- Major version tracks the targeted .NET runtime release for simpler release management. -->
        <CohesionMajorVersion>$([System.Version]::Parse('$(TargetFramework.TrimStart('net'))').Major)</CohesionMajorVersion>
        <CohesionMinorVersion>0</CohesionMinorVersion>
        <CohesionPatchVersion>2-preview.1</CohesionPatchVersion>
        <CohesionVersion>$(CohesionMajorVersion).$(CohesionMinorVersion).$(CohesionPatchVersion)</CohesionVersion>
    </PropertyGroup>

    <PropertyGroup Condition="'$(IsPackable)' != 'false'">
		<Version Condition="'$(Version)' == ''">$(CohesionVersion)</Version>
		<PackageVersion Condition="'$(PackageVersion)' == ''">$(Version)</PackageVersion>
		<PackageOutputPath Condition="'$(PackageOutputPath)' == ''">$(CohesionOutputPathForLibraries)</PackageOutputPath>
	</PropertyGroup>
</Project>