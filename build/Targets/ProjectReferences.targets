<Project>
    <!-- #region: Project Reference Update By Name -->
	<ItemGroup>
        <CohesionProject Include="$(CohesionRepositoryDirectory)**\*.csproj" />
        <CohesionProject Update="@(CohesionProject)" ProjectId="%(CohesionProject.Filename)" ProjectPath="%(CohesionProject.Identity)" />
        <CohesionProjectReference Update="@(CohesionProject->'%(ProjectId)')" ProjectPath="%(CohesionProject.ProjectPath)" />
        <ProjectReference Include="@(CohesionProjectReference->'%(ProjectPath)')" />
        <CohesionProjectReference Remove="@(CohesionProjectReference->HasMetadata('ProjectPath'))" />
        <CohesionProjectProject Remove="@(CohesionProject)" />
    </ItemGroup>
	<!-- #endregion -->
</Project>