<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<RootNamespace>Assimalign.Cohesion.Logging</RootNamespace>
		<Description>Cohesion logging foundation: structured log event model, logger contracts, factory composition, scope and enrichment primitives. Concrete sinks live in sibling packages.</Description>
	</PropertyGroup>
	<ItemGroup>
		<CohesionProjectReference Include="Assimalign.Cohesion.Core" />
	</ItemGroup>
	<ItemGroup>
		<CohesionValueType
			Include="ValueTypes\LogId.cs"
			ObjectRuntimeType="Ulid"
			ObjectNamespace="Assimalign.Cohesion.Logging"
			ObjectAccessModifier="public"
			ObjectHasImplicitOperators="true" />
	</ItemGroup>
</Project>
