<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<RootNamespace>Assimalign.Cohesion.Logging.Debug</RootNamespace>
		<Description>Debug sink for Cohesion logging. Emits structured log entries via System.Diagnostics.Debug, gated on whether a debugger is attached.</Description>
	</PropertyGroup>
	<ItemGroup>
		<CohesionProjectReference Include="Assimalign.Cohesion.Logging" />
	</ItemGroup>
	<ItemGroup>
		<None Include="..\README.md" Condition="Exists('..\README.md')">
			<Pack>true</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
</Project>
