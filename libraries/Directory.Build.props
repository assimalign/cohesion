<Project>
	<Import Project="..\Directory.Build.props" />
	<!-- #region Frameworks Specific Props
			All projects should follow the same directory pattern
			/ Service 
				/ Library
					/src
					/test
		-->
	<PropertyGroup>
		<TargetFrameworks>$(TargetFrameworkForLibraries)</TargetFrameworks>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<TargetLatestRuntimePatch>true</TargetLatestRuntimePatch>
		<RollForward>LatestPatch</RollForward>
		<!-- AOT-->
		<IsAotCompatible Condition="$(MSBuildProjectDirectory.EndsWith('src'))">true</IsAotCompatible>
		<StripSymbols Condition="$(MSBuildProjectDirectory.EndsWith('src'))">false</StripSymbols>
	</PropertyGroup>
	<!-- #endregion -->

	<!-- #region Packaging Props-->
	<PropertyGroup Condition="$(MSBuildProjectDirectory.EndsWith('src'))">
		<PackageVersion>$(CohesionVersion)</PackageVersion>
		<AssemblyVersion>$(CohesionVersion)</AssemblyVersion>
		<GenerateRuntimeConfigurationFiles Condition="'$(Configuration)' == 'Release'">true</GenerateRuntimeConfigurationFiles>
		<GeneratePackageOnBuild Condition="'$(Configuration)' == 'Release'">true</GeneratePackageOnBuild>
		<PackageLicenseFile Condition="Exists('$(MSBuildProjectDirectory)\..\..\..\..\LICENSE')">LICENSE</PackageLicenseFile>
		<PackageReadmeFile Condition="Exists('$(MSBuildProjectDirectory)\..\README.md')">README.md</PackageReadmeFile>
		<!-- <PackageOutputPath>$(CohesionOutputPathForLibraries)\$(PackageId)</PackageOutputPath> -->
	</PropertyGroup>
	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<!-- <SignAssembly>true</SignAssembly>
		<AssemblyOriginatorKeyFile>..\sharedkey.snk</AssemblyOriginatorKeyFile> -->
	</PropertyGroup>
	<ItemGroup Condition="$(MSBuildProjectDirectory.EndsWith('src'))">
		<None Include="..\README.md" Condition="Exists('$(MSBuildProjectDirectory)\..\README.md')">
			<Pack>true</Pack>
			<PackagePath>\</PackagePath>
		</None>
		<None Include="..\..\..\..\LICENSE" Condition="Exists('$(MSBuildProjectDirectory)\..\..\..\..\LICENSE')">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
	<!-- #endregion-->
</Project>