<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<RootNamespace>Assimalign.Cohesion.Http</RootNamespace>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<ImplicitUsings>disable</ImplicitUsings>
		<Description>HTTP form-body parsing model for the Cohesion HTTP family. Layered on top of Assimalign.Cohesion.Http; defines IHttpFormCollection and IHttpFormFile so server-side consumers can opt into form parsing. Protocol-only consumers (clients, proxies, edge caches) should not reference this package.</Description>
	</PropertyGroup>
	<ItemGroup>
		<CohesionProjectReference Include="Assimalign.Cohesion.Http" />
	</ItemGroup>
	<ItemGroup>
		<!-- WIP: ASP.NET Core port in progress; the in-flight parser files reference
		     types (StringValues, etc.) that the Cohesion stack doesn't yet expose.
		     Excluded from the build until the port lands; their content is preserved
		     in-tree as a checkpoint. -->
		<Compile Remove="FormReader.cs" />
		<Compile Remove="KeyValueAccumulator.cs" />
		<Compile Remove="HttpFormOptions.cs" />
	</ItemGroup>
</Project>
