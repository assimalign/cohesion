<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>A collection of generic network transports for creating client and server implementations.</Description>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="Transports\Quic\**" />
		<Compile Remove="Transports\Udp\**" />
		<EmbeddedResource Remove="Transports\Quic\**" />
		<EmbeddedResource Remove="Transports\Udp\**" />
		<None Remove="Transports\Quic\**" />
		<None Remove="Transports\Udp\**" />
	</ItemGroup>
	<ItemGroup>
		<Reference Include="Assimalign.Cohesion.Core" />
	</ItemGroup>
	<ItemGroup>
		<ValueObject Include="$(MSBuildProjectDirectory)\ValueObjects\ConnectionId.cs">
			<Name>ConnectionId</Name>
			<RuntimeType>Ulid</RuntimeType>
			<IsStruct>true</IsStruct>
			<Namespace>Assimalign.Cohesion.Transports</Namespace>
			<IncludeIsValidMethod>false</IncludeIsValidMethod>
			<IncludeImplicitOperators>true</IncludeImplicitOperators>
		</ValueObject>
		<ValueObject Include="$(MSBuildProjectDirectory)\ValueObjects\TransportId.cs">
			<Name>TransportId</Name>
			<RuntimeType>Ulid</RuntimeType>
			<IsStruct>true</IsStruct>
			<Namespace>Assimalign.Cohesion.Transports</Namespace>
			<IncludeIsValidMethod>false</IncludeIsValidMethod>
			<IncludeImplicitOperators>true</IncludeImplicitOperators>
		</ValueObject>
		<ValueObject Include="$(MSBuildProjectDirectory)\ValueObjects\TransportProtocol.cs">
			<Name>TransportProtocol</Name>
			<RuntimeType>String</RuntimeType>
			<IsStruct>true</IsStruct>
			<Namespace>Assimalign.Cohesion.Transports</Namespace>
			<IncludeIsValidMethod>false</IncludeIsValidMethod>
			<IncludeImplicitOperators>true</IncludeImplicitOperators>
		</ValueObject>
	</ItemGroup>
</Project>