<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<PackageId>Assimalign.Cohesion.Core</PackageId>
		<RootNamespace>Assimalign.Cohesion</RootNamespace>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>
	<ItemGroup>
		<Compile Remove="Shared\**" Visible="true" />
		<EmbeddedResource Remove="Shared\**" />
		<None Include="Shared\**\*.cs">
			<Visible>true</Visible>
		</None>
	</ItemGroup>
	<ItemGroup>
		<Compile Remove="System\Net\CidrBlock.cs" />
	</ItemGroup>
	<ItemGroup>
		<Compile Update="Properties\ErrorMessages.Designer.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>ErrorMessages.resx</DependentUpon>
		</Compile>
	</ItemGroup>
	<ItemGroup>
		<EmbeddedResource Update="Properties\ErrorMessages.resx">
			<Generator>ResXFileCodeGenerator</Generator>
			<LastGenOutput>ErrorMessages.Designer.cs</LastGenOutput>
		</EmbeddedResource>
	</ItemGroup>
	<ItemGroup>
	  <Folder Include="System\Decorators\" />
	</ItemGroup>
</Project>
