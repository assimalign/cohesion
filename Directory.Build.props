<Project>
	<Import Project="Version.props" />
	<!-- Branding -->
	<PropertyGroup>
		<Company>Assimalign</Company>
		<Copyright>© Assimalign $([System.DateTime]::Now.ToString(`yyyy`))</Copyright>
		<RepositoryType>git</RepositoryType>
		<RepositoryUrl>https://github.com/assimalign/cohesion</RepositoryUrl>
	</PropertyGroup>
	<!-- Target Frameworks -->
	<PropertyGroup>
		<TargetFrameworkLatest>net9.0</TargetFrameworkLatest>
		<TargetFrameworkForLibraries>$(TargetFrameworkLatest)</TargetFrameworkForLibraries>
		<TargetFrameworkForShared>$(TargetFrameworkLatest)</TargetFrameworkForShared>
		<TargetFrameworkForCli>$(TargetFrameworkLatest)</TargetFrameworkForCli>
		<TargetFrameworkForPortal>$(TargetFrameworkLatest)</TargetFrameworkForPortal>
		<TargetFrameworkForSdk>$(TargetFrameworkLatest)</TargetFrameworkForSdk>
	</PropertyGroup>
	<!-- Cohesion Build Properties -->
	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<DebugType>none</DebugType>
		<CohesionRepositoryDirectory>$(MSBuildThisFileDirectory)</CohesionRepositoryDirectory>
		<CohesionOutputPath>$(CohesionRepositoryDirectory)_out</CohesionOutputPath>
		<CohesionOutputPathForSdk>$(CohesionOutputPath)\dotnet\sdk</CohesionOutputPathForSdk>
		<CohesionOutputPathForFramework>$(CohesionOutputPath)\dotnet\shared</CohesionOutputPathForFramework>
		<CohesionOutputPathForLibraries>$(CohesionOutputPath)\packages</CohesionOutputPathForLibraries>
	</PropertyGroup>
	<!-- Add Runtime Constants -->
	<PropertyGroup>
		<DefineConstants Condition="$([System.OperatingSystem]::IsWindows())">$(DefineConstants);IS_WINDOWS</DefineConstants>
		<DefineConstants Condition="$([System.OperatingSystem]::IsLinux())">$(DefineConstants);IS_LINUX</DefineConstants>
		<DefineConstants Condition="$([System.OperatingSystem]::IsMacOS())">$(DefineConstants);IS_MAC</DefineConstants>
	</PropertyGroup>
</Project>