<Project>
	<!-- Branding -->
	<PropertyGroup>
		<Company>Assimalign</Company>
		<Copyright>© Assimalign $([System.DateTime]::Now.ToString(`yyyy`))</Copyright>
		<RepositoryType>git</RepositoryType>
		<RepositoryUrl>https://github.com/assimalign-cohesion/cohesion</RepositoryUrl>
	</PropertyGroup>
	<!-- Fixed Version Info -->
	<PropertyGroup>
		<MajorVersion>1</MajorVersion>
		<MinorVersion>0</MinorVersion>
		<PatchVersion>0</PatchVersion>
	</PropertyGroup>
	<!-- Target Frameworks -->
	<PropertyGroup>
		<TargetFrameworkLatest>net9.0</TargetFrameworkLatest>
		<TargetFrameworkForLibraries>net6.0;net8.0;$(TargetFrameworkLatest)</TargetFrameworkForLibraries>
		<TargetFrameworkForBenchmark>$(TargetFrameworkLatest)</TargetFrameworkForBenchmark>
		<TargetFrameworkForCli>$(TargetFrameworkLatest)</TargetFrameworkForCli>
		<TargetFrameworkForPortal>$(TargetFrameworkLatest)</TargetFrameworkForPortal>
		<TargetFrameworkForSdk>$(TargetFrameworkLatest)</TargetFrameworkForSdk>
	</PropertyGroup>
	<!-- Cohesion Build Properties -->
	<PropertyGroup>
		<CohesionVersion>$(MajorVersion).$(MinorVersion).$(PatchVersion)</CohesionVersion>
		<CohesionRepositoryDirectory>$(MSBuildThisFileDirectory)</CohesionRepositoryDirectory>
	</PropertyGroup>
</Project>