		<CohesionProjectReference Include="Assimalign.Cohesion.Database.ApplicationModel" />
		<CohesionProjectReference Include="Assimalign.Cohesion.ApplicationModel.Gateway" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Connections.Tcp" />
