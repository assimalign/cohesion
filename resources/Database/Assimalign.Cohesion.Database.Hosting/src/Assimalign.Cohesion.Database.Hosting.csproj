<Project Sdk="Microsoft.NET.Sdk">
	<!--
		Composition-only, COHRES002-clean: the hosting module references only the
		area root inside the area, plus the non-area Hosting foundation. The server
		runtime lives in Assimalign.Cohesion.Database.Server (shared server
		infrastructure above the root, so per-model servers can derive from it);
		this module composes IDatabaseServer instances generically as host services
		and needs no transport (Connections) or wire (Protocol) knowledge at all.
	-->
	<ItemGroup>
		<CohesionProjectReference Include="Assimalign.Cohesion.Database" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Hosting" />
	</ItemGroup>
</Project>
