<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<IsPackable>false</IsPackable>
	</PropertyGroup>
	<ItemGroup>
		<CohesionPackageReference Include="Microsoft.NET.Test.Sdk" />
		<CohesionPackageReference Include="coverlet.collector" />
		<CohesionPackageReference Include="xunit" />
		<CohesionPackageReference Include="xunit.runner.visualstudio" />
		<CohesionPackageReference Include="Shouldly" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Database.Hosting" />
		<!-- Composition acceptance: the host runs a real SQL engine + the wire server
		     (owned by Hosting) over the in-memory driver, driven end-to-end by a
		     client (tests are exempt from the area layering rules). -->
		<CohesionProjectReference Include="Assimalign.Cohesion.Database.Sql" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Database.Client" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Connections.InMemory" />
	</ItemGroup>
</Project>
