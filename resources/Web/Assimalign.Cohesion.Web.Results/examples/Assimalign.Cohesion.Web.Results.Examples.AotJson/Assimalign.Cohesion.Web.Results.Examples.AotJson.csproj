<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!--
        NativeAOT validation smoke for the IResult foundation (#864). A representative Web.Api
        endpoint (real router + MapGet) returns Results.Ok<T> serialized through a source-generated
        JsonTypeInfo<T>, served over the real HTTP/1.1 transport and asserted by a real client.
        Published with PublishAot and RUN to record the evidence the project docs reference:

            dotnet publish resources/Web/Assimalign.Cohesion.Web.Results/examples/Assimalign.Cohesion.Web.Results.Examples.AotJson/Assimalign.Cohesion.Web.Results.Examples.AotJson.csproj -c Release -r win-arm64

        (On LongPathsEnabled=0 machines, run from a short path - the main checkout or a
        subst-mapped drive - because ILC intermediate paths are long. On Windows the publish
        needs the VS dev shell for the native linker.)
    -->
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <PublishAot>true</PublishAot>
    <WarningsAsErrors>$(WarningsAsErrors);IL2026;IL2070;IL2072;IL2075;IL2087;IL3050;IL3051</WarningsAsErrors>
  </PropertyGroup>
  <ItemGroup>
    <CohesionProjectReference Include="Assimalign.Cohesion.Web.Results" />
    <CohesionProjectReference Include="Assimalign.Cohesion.Web" />
    <CohesionProjectReference Include="Assimalign.Cohesion.Web.Api" />
    <CohesionProjectReference Include="Assimalign.Cohesion.Web.Routing" />
    <CohesionProjectReference Include="Assimalign.Cohesion.Http" />
    <CohesionProjectReference Include="Assimalign.Cohesion.Http.Connections" />
    <CohesionProjectReference Include="Assimalign.Cohesion.Connections" />
    <CohesionProjectReference Include="Assimalign.Cohesion.Connections.Tcp" />
  </ItemGroup>
</Project>
