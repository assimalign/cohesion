<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>The OnError fault seam for the Cohesion Web pipeline: builder-time registration of the error handlers through which an application owns its fault responses (AddErrorHandling().OnError(...)), the IHttpErrorHandlingFeature exchange feature that exception boundaries invoke, and the terminal default that renders the RFC 9457 Web.ProblemDetails payload. Faults only — expected protocol outcomes (401 challenges, 404s, 415s) remain each feature's normal response path.</Description>
	</PropertyGroup>
	<ItemGroup>
		<CohesionProjectReference Include="Assimalign.Cohesion.Http" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Web" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Web.ProblemDetails" />
	</ItemGroup>
</Project>
