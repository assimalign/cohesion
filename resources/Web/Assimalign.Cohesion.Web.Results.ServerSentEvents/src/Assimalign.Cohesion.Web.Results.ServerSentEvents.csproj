<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>The Server-Sent Events result adapter for the Cohesion Web pipeline: a ServerSentEvents built-in result over the response-streaming feature plus Results/TypedResults factory extensions. Kept out of the core Assimalign.Cohesion.Web.Results package so its dependency tree stays lean — only applications that stream events pull in the SSE primitives.</Description>
		<!-- Deviates from the repo namespace-matches-assembly rule per design decision:
		     this adapter surfaces its types in the Assimalign.Cohesion.Web.Results
		     namespace so the Results.ServerSentEvents(...) / TypedResults.ServerSentEvents(...)
		     static extension factories are discoverable with the same using directive as the
		     core factories (matches the Assimalign.Cohesion.Http feature-package precedent). -->
		<RootNamespace>Assimalign.Cohesion.Web.Results</RootNamespace>
	</PropertyGroup>
	<ItemGroup>
		<CohesionProjectReference Include="Assimalign.Cohesion.Web.Results" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Http" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Http.Streaming" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Http.ServerSentEvents" />
	</ItemGroup>
</Project>
