<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<IsPackable>false</IsPackable>
	</PropertyGroup>
	<ItemGroup>
		<CohesionPackageReference Include="coverlet.collector" />
		<CohesionPackageReference Include="Shouldly" />
		<CohesionPackageReference Include="Microsoft.NET.Test.Sdk" />
		<CohesionPackageReference Include="xunit" />
		<CohesionPackageReference Include="xunit.runner.visualstudio" />
	</ItemGroup>
	<ItemGroup>
		<CohesionProjectReference Include="Assimalign.Cohesion.Web.Authentication" />
		<!-- The composition tests drive the handler packages' grafted AddCookie/AddJwtBearer
		     verbs end-to-end, so the test project (not the library) references them. -->
		<CohesionProjectReference Include="Assimalign.Cohesion.Web.Authentication.Cookie" />
		<CohesionProjectReference Include="Assimalign.Cohesion.Web.Authentication.Bearer" />
	</ItemGroup>
</Project>
