{
    "vsicons.associations.folders": [
        {
            "icon": "docs",
            "extensions": [
                ".docs"
            ]
        },
        {
            "icon": "tools",
            "extensions": [
                "tooling"
            ]
        },
        {
            "icon": "scripts",
            "extensions": [
                ".scripts"
            ]
        },
        {
            "icon": "github",
            "extensions": [
                ".github"
            ]
        },
        {
            "icon": "services",
            "extensions": [
                "libraries"
            ]
        }
    ],
    "files.associations": {
        "**/.github/**/*.yml": "github-actions-workflow"
    },
    "explorer.fileNesting.enabled": true,
    "files.exclude": {
        // "_out": true,
        "**/.vs/**": true
    },
    "dotnet.preferCSharpExtension": true,
    "dotnet.defaultSolution": "Assimalign.Cohesion.sln",
    "chat.tools.terminal.autoApprove": {
        "ForEach-Object": true
    }
}